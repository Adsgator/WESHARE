# ─────────────────────────────────────────────
# CONFIGURAÇÃO DO PROJETO — preencha tudo antes de começar
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Site
PUBLIC_SITE_URL=https://DOMINIO-DO-CLIENTE.com.br
PUBLIC_SITE_NAME=NOME DO CLIENTE

# Google Tag Manager
PUBLIC_GTM_ID=GTM-XXXXXXX

# WhatsApp (só números, com DDI: 5511999999999)
PUBLIC_WA_NUMBER=55XXXXXXXXXXX
PUBLIC_WA_MESSAGE=Olá! Vim pelo site e gostaria de saber mais.

# SEO padrão
PUBLIC_SEO_TITLE=TÍTULO DA PÁGINA — NOME DO CLIENTE
PUBLIC_SEO_DESCRIPTION=DESCRIÇÃO DO SITE EM ATÉ 160 CARACTERES
PUBLIC_SEO_KEYWORDS=palavra-chave 1, palavra-chave 2, palavra-chave 3
