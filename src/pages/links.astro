---
import { Image } from "astro:assets";
import bannerHero from "../assets/images/banner_links.webp";
import logoAvatar from "../assets/images/avatar_links.webp";

export const prerender = true;

const GTM_ID = import.meta.env.PUBLIC_GTM_ID || "";

const perfil = {
  nome: "WeShare",
  cargo: "Escritórios Compartilhados",
  cargo2: "Jardim Aquarius — SJC",
};

const links = [
  {
    id:       "btn-links-site",
    label:    "Acessar o site",
    href:     "https://wesharescritorios.com.br",
    tracking: "click-site-links",
    variant:  "primary",
    newTab:   false,
    iconSVG:  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>',
  },
  {
    id:       "btn-links-endereco",
    label:    "Nosso endereço",
    href:     "https://maps.app.goo.gl/bEpSffjYUhYwHKMj9",
    tracking: "click-endereco-links",
    variant:  "ghost",
    newTab:   true,
    iconSVG:  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
  },
  {
    id:       "btn-links-avaliacoes",
    label:    "Deixe sua avaliação",
    href:     "https://g.page/r/CWo0mhE9A-dpEAE/review",
    tracking: "click-avaliacoes-links",
    variant:  "ghost",
    newTab:   true,
    iconSVG:  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  },
  {
    id:       "btn-links-wa",
    label:    "Fale conosco",
    href:     "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.",
    tracking: "click-whatsapp-links",
    variant:  "ghost",
    newTab:   true,
    iconSVG:  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>',
  },
];

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />

  {GTM_ID && (
    <script is:inline define:vars={{ GTM_ID }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',GTM_ID);
    </script>
  )}

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, follow" />
  <meta name="theme-color" content="#274c3b" />
  <title>WeShare Escritórios Compartilhados | Links</title>
  <meta name="description" content="Endereço fiscal e coworking no Jardim Aquárius, São José dos Campos. Fale conosco pelo WhatsApp." />
  <link rel="canonical" href="https://wesharescritorios.com.br/links" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:title" content="WeShare Escritórios Compartilhados | Links" />
  <meta property="og:description" content="Endereço fiscal e coworking no Jardim Aquárius, São José dos Campos." />
  <meta property="og:type" content="website" />

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'analytics_storage': 'denied',
      'wait_for_update': 500
    });
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Poppins:wght@500;600&display=swap"
    rel="stylesheet"
  />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'Montserrat', ui-sans-serif, system-ui, sans-serif;
      font-weight: 300;
      background-color: #f2f5f3;
      color: #333333;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ── Layout geral ──────────────────────────── */
    .links-page {
      min-height: 100vh;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ── Hero Banner ───────────────────────────── */
    .hero-banner {
      position: relative;
      width: 100%;
      max-width: 430px;
      height: 220px;
      overflow: hidden;
      flex-shrink: 0;
    }

    .hero-banner__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      display: block;
    }

    .hero-banner__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(39, 76, 59, 0.18) 0%,
        rgba(34, 34, 34, 0.52) 100%
      );
    }

    /* ── Card Principal ────────────────────────── */
    .profile-card {
      width: 100%;
      max-width: 430px;
      background-color: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 20px 48px;
      flex: 1;
    }

    /* ── Avatar ────────────────────────────────── */
    .avatar-wrapper {
      margin-top: -44px;
      z-index: 10;
      position: relative;
    }

    .avatar {
      width: 88px;
      height: 88px;
      border-radius: 12px;
      object-fit: contain;
      object-position: center;
      border: 4px solid #ffffff;
      box-shadow: 0 4px 20px rgba(39, 76, 59, 0.18);
      display: block;
      background-color: #f2f5f3;
      padding: 8px;
    }

    /* ── Perfil Info ───────────────────────────── */
    .profile-info {
      margin-top: 14px;
      text-align: center;
      margin-bottom: 28px;
    }

    .profile-name {
      font-family: 'Poppins', ui-sans-serif, system-ui, sans-serif;
      font-size: 1.55rem;
      font-weight: 600;
      color: #274c3b;
      letter-spacing: -0.01em;
      line-height: 1.15;
    }

    .profile-role {
      font-family: 'Montserrat', system-ui, sans-serif;
      font-size: 10.5px;
      font-weight: 600;
      color: #666666;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-top: 6px;
    }

    /* ── Lista de Links ─────────────────────────── */
    .links-list {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 11px;
    }

    /* ── Link Button ────────────────────────────── */
    .link-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 16px 24px;
      font-family: 'Montserrat', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 0.02em;
      text-decoration: none;
      border-radius: 6px;
      border: none;
      transition: background-color 0.18s ease, transform 0.15s ease,
        box-shadow 0.18s ease, border-color 0.18s ease, color 0.18s ease;
      cursor: pointer;
    }

    .link-btn:hover  { transform: translateY(-1px); }
    .link-btn:active { transform: translateY(0); }

    .link-btn:focus-visible {
      outline: 2px solid #274c3b;
      outline-offset: 2px;
    }

    .link-btn.primary {
      background-color: #274c3b;
      color: #ffffff;
      box-shadow: 0 2px 14px rgba(39, 76, 59, 0.30);
    }

    .link-btn.primary:hover {
      background-color: #1d3a2c;
      box-shadow: 0 4px 20px rgba(39, 76, 59, 0.42);
    }

    .link-btn.ghost {
      background-color: #ffffff;
      color: #333333;
      border: 1px solid #d9e6df;
      box-shadow: 0 1px 4px rgba(39, 76, 59, 0.07);
    }

    .link-btn.ghost:hover {
      border-color: #274c3b;
      color: #274c3b;
      box-shadow: 0 4px 14px rgba(39, 76, 59, 0.12);
    }

    /* ── Rodapé ─────────────────────────────────── */
    .page-footer {
      margin-top: 40px;
      font-family: 'Montserrat', system-ui, sans-serif;
      font-size: 10.5px;
      color: rgba(51, 51, 51, 0.38);
      text-align: center;
      line-height: 1.6;
    }

    /* ── Animações ──────────────────────────────── */
    .link-item {
      opacity: 0;
      transform: translateY(20px);
    }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .link-item {
        opacity: 1;
        transform: none;
        animation: none !important;
      }
    }
  </style>
</head>
<body>
  {GTM_ID && (
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0" width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
  )}

  <main class="links-page">

    <!-- ── HERO BANNER ───────────────────────────── -->
    <div class="hero-banner" role="img" aria-label="Fachada do WeShare Escritórios Compartilhados">
      <Image
        src={bannerHero}
        alt="Fachada do WeShare Escritórios Compartilhados"
        class="hero-banner__img"
        width={860}
        height={480}
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero-banner__overlay" aria-hidden="true"></div>
    </div>

    <!-- ── CARD PRINCIPAL ────────────────────────── -->
    <div class="profile-card">

      <!-- Logo na divisória -->
      <div class="avatar-wrapper link-item" style="animation: fadeUp 0.5s 0s ease both">
        <Image
          src={logoAvatar}
          alt="WeShare Escritórios Compartilhados"
          class="avatar"
          width={200}
          height={200}
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Nome + Cargo -->
      <div class="profile-info link-item" style="animation: fadeUp 0.5s 0.07s ease both">
        <h1 class="profile-name">{perfil.nome}</h1>
        <p class="profile-role">{perfil.cargo}</p>
        <p class="profile-role">{perfil.cargo2}</p>
      </div>

      <!-- Links -->
      <div class="links-list" role="list">
        {links.map((link, i) => (
          <div role="listitem" class="link-item" style={`animation: fadeUp 0.5s ${0.14 + i * 0.08}s ease both`}>
            <a
              href={link.href}
              id={link.id}
              data-tracking={link.tracking}
              data-section="links"
              class={`link-btn ${link.variant}`}
              {...link.newTab ? { target: "_blank", rel: "noopener noreferrer" } : {}}
            >
              <span class="link-btn-icon" aria-hidden="true" set:html={link.iconSVG}></span>
              <span>{link.label}</span>
            </a>
          </div>
        ))}
      </div>

      <!-- Rodapé -->
      <footer class="page-footer link-item" style={`animation: fadeUp 0.5s ${0.14 + links.length * 0.08}s ease both`}>
        <p>© {currentYear} WeShare Escritórios Compartilhados</p>
      </footer>

    </div>
  </main>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'view_links', page_type: 'links_page' });

    document.addEventListener('click', function(e) {
      var el = e.target.closest('[data-tracking]');
      if (!el) return;
      var action = el.getAttribute('data-tracking');
      var section = el.getAttribute('data-section');
      window.dataLayer.push({ event: 'link_click', click_action: action, click_section: section });
      if (action && action.includes('whatsapp')) {
        window.dataLayer.push({ event: 'contato_wpp', click_action: action, click_section: section });
      }
    });
  </script>
</body>
</html>
