---
// Página inicial do projeto.
// Importe aqui os componentes de seção da biblioteca Astroteca e do projeto.
//
// Estrutura esperada:
//   Layout (infraestrutura: GTM, SEO, WhatsApp, CookieBanner, ScrollAnimations)
//     Header     ← componente da biblioteca Astroteca
//     seções...  ← componentes do projeto / biblioteca
//     Footer     ← componente da biblioteca Astroteca
//
// TODO: importe Header, Footer e as seções da biblioteca Astroteca conforme o projeto.

import Avaliacoes from "../components/sections/Avaliacoes.astro";
import ComoFunciona from "../components/sections/ComoFunciona.astro";
import CtaFinal from "../components/sections/CtaFinal.astro";
import Diferenciais from "../components/sections/Diferenciais.astro";
import FAQ from "../components/sections/FAQ.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import Hero from "../components/sections/Hero.astro";
import Precos from "../components/sections/Precos.astro";
import Servicos from "../components/sections/Servicos.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <Header />

  <main id="main-content" tabindex="-1">
    <Hero />
    <Servicos />
    <ComoFunciona />
    <Diferenciais />
    <Precos />
    <FAQ />
    <Avaliacoes />
    <CtaFinal />
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  // Rastreamento de cliques WhatsApp via dataLayer (GTM)
  document.addEventListener("click", function (e) {
    var el = e.target.closest("[data-tracking]");
    if (!el) return;
    var action = el.getAttribute("data-tracking");
    var section = el.getAttribute("data-section");
    if (action && action.includes("whatsapp")) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "contato_wpp",
        click_action: action,
        click_section: section || "unknown",
      });
    }
  });
</script>
