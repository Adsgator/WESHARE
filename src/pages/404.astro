---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";

const waNumber = import.meta.env.PUBLIC_WA_NUMBER || "5512982710971";
const waMessage =
  import.meta.env.PUBLIC_WA_MESSAGE || "Olá! Vi seu site e gostaria de mais informações.";
const WA_LINK = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;
---

<BaseLayout
  title="Página não encontrada | WeShare Escritórios Compartilhados"
  noindex={true}
>
  <Header />

  <main id="main-content" class="not-found">
    <p class="bg-number" id="bg-404" aria-hidden="true">404</p>

    <div class="content">
      <p class="label">Oops</p>
      <h1>Essa página não foi encontrada</h1>
      <p>A página que você buscou não existe mais ou foi movida. Fale com a WeShare pelo WhatsApp ou volte ao início.</p>
      <div class="btn-group">
        <a href="/" class="btn-primary" id="btn-404-home">
          Voltar ao início
        </a>
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
          id="btn-404-whatsapp"
        >
          Falar no WhatsApp
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found {
    background: var(--t-background);
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
    position: relative;
    overflow: hidden;
  }

  .bg-number {
    position: absolute;
    font-family: var(--t-font-serif);
    font-size: clamp(200px, 40vw, 360px);
    font-weight: 300;
    color: color-mix(in srgb, var(--t-primary) 6%, transparent);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .content {
    position: relative;
    z-index: 1;
    max-width: 420px;
  }

  .label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--t-primary);
    margin-bottom: 16px;
  }

  .content h1 {
    font-family: var(--t-font-serif);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 14px;
    color: var(--t-text-main);
  }

  .content p {
    font-size: 0.95rem;
    color: var(--t-text-soft);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .btn-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-number { animation: none; }
  }
</style>

<script is:inline>
  (function () {
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;
    var el = document.getElementById('bg-404');
    if (!el) return;
    var start = null;
    function animate(ts) {
      if (!start) start = ts;
      var elapsed = (ts - start) / 1000;
      var y = Math.sin(elapsed * (Math.PI / 4)) * 10;
      el.style.transform = 'translateY(' + y + 'px)';
      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  })();
</script>
