---
import GTM from "../components/global/GTM.astro";
import SkipLink from "../components/global/SkipLink.astro";
import WhatsAppFloat from "../components/global/WhatsAppFloat.astro";
import CookieBanner from "../components/islands/CookieBanner.tsx";
import ScrollAnimations from "../components/islands/ScrollAnimations.tsx";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonical?: string;
  noindex?: boolean;
  schema?: object;
}

const SITE_URL = "https://wesharescritorios.com.br";

const {
  title = "WeShare Escritorios Compartilhados | Endereco Fiscal e Coworking no Jardim Aquarius - SJC",
  description = "Endereco fiscal e comercial de prestigio no Jardim Aquarius, Sao Jose dos Campos, por R$ 119,90/mes. Documentacao no mesmo dia, sem fidelidade. Escritorios privativos e salas de reuniao para reservar pelo WhatsApp.",
  keywords = "endereco fiscal Sao Jose dos Campos, escritorio compartilhado, coworking Jardim Aquarius, sala de reuniao SJC, escritorio privativo, endereco comercial CNPJ",
  ogTitle = "WeShare Escritorios Compartilhados | Jardim Aquarius - Sao Jose dos Campos",
  ogDescription = "Seu CNPJ com endereco de prestigio por R$ 119,90/mes. Documentacao no mesmo dia, sem fidelidade e com gestao de correspondencia inclusa.",
  canonical = SITE_URL,
  noindex = false,
  schema,
} = Astro.props;

const GTM_ID = import.meta.env.PUBLIC_GTM_ID || "";
const DEFAULT_THEME = "light";

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "WeShare Escritorios Compartilhados",
  description:
    "Endereco fiscal e comercial, escritorios privativos, salas de reuniao e estacoes compartilhadas no Jardim Aquarius, Sao Jose dos Campos.",
  url: SITE_URL,
  telephone: "+55-12-98271-0971",
  email: "contato@wesharescritorios.com.br",
  priceRange: "R$$",
  address: {
    "@type": "PostalAddress",
    streetAddress:
      "Av. Alfredo Ignacio Nogueira Penido, 335, Ed. Medison Tower, Sala 706, Jardim Aquarius",
    addressLocality: "Sao Jose dos Campos",
    addressRegion: "SP",
    postalCode: "12246-000",
    addressCountry: "BR",
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    opens: "00:00",
    closes: "23:59",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5",
    reviewCount: "54",
  },
  sameAs: ["https://www.instagram.com/wesharescritorios"],
};

const finalSchema = schema || defaultSchema;
---

<!DOCTYPE html>
<html lang="pt-BR" data-default-theme={DEFAULT_THEME}>
<head>
  <meta charset="UTF-8" />

  <script is:inline>
    (function () {
      var stored = localStorage.getItem("theme");
      var theme =
        stored ||
        document.documentElement.dataset.defaultTheme ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");

      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      }
    })();
  </script>

  {GTM_ID && <GTM id={GTM_ID} />}

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#274C3B" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={`${SITE_URL}/og-image.svg`} />
  <meta property="og:locale" content="pt_BR" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={`${SITE_URL}/og-image.svg`} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Poppins:wght@500;600;700&display=swap"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Poppins:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag("consent", "default", {
      ad_storage: "denied",
      analytics_storage: "denied",
      ad_user_data: "denied",
      ad_personalization: "denied",
      wait_for_update: 500,
    });
  </script>
</head>
<body>
  {GTM_ID && (
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
  )}

  <SkipLink />
  <slot />
  <WhatsAppFloat />
  <CookieBanner client:idle />
  <ScrollAnimations client:load />
</body>
</html>
