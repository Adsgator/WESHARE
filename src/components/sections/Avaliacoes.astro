---
import { Image } from "astro:assets";
import ambienteReuniao from "../../assets/images/ambiente_reuniao_webp.webp";
import ambienteFachada from "../../assets/images/ambiente_fachada_webp.webp";
import ambientePrivativo from "../../assets/images/ambiente_privativo_webp.webp";
import ambienteLounge from "../../assets/images/ambiente_lounge_webp.webp";
import ambienteConferencia from "../../assets/images/ambiente_conferencia_webp.webp";

const ambientes = [
  {
    label: "Sala de Reunião",
    image: ambienteReuniao,
    size: "1600 x 900",
    className: "md:col-span-12 aspect-[16/9]",
  },
  {
    label: "Endereço Fiscal",
    image: ambienteFachada,
    size: "1080 x 1320",
    className: "md:col-span-7 aspect-[1080/1320]",
  },
  {
    label: "Escritório Privativo",
    image: ambientePrivativo,
    size: "860 x 1320",
    className: "md:col-span-5 aspect-[860/1320]",
  },
  {
    label: "Sala de reunião completa",
    image: ambienteLounge,
    size: "1080 x 720",
    className: "md:col-span-6 aspect-[1080/720]",
  },
  {
    label: "Escritório climatizado",
    image: ambienteConferencia,
    size: "860 x 720",
    className: "md:col-span-6 aspect-[860/720]",
  },
];

const depoimentos = [
  {
    texto:
      "Espaço perfeito para trabalhar em paz. Internet muito rápida e confiável, móveis confortáveis e adequados, localização ideal. O café expresso e água são cortesia, e Renato fará tudo o que puder para ajudar. Certamente voltarei quando precisar.",
    nome: "Andre Embersics",
  },
  {
    texto:
      "Tive uma excelente experiência no Edifício Madison Tower. A estrutura é moderna e muito bem localizada, perfeita para reuniões profissionais. Agradecimento especial ao Renato, extremamente atencioso e prestativo. Recomendo muito!",
    nome: "Diego Brison",
  },
  {
    texto:
      "Supera agilidade, pedi uma agenda de última hora e o pessoal foi super solícito em preparar e deixar tudo ajustado para nossa agenda. O suporte foi super atencioso no processo. Recomendo.",
    nome: "Carlos Arruda",
  },
];
---

<section class="bg-surface">
  <div class="container-wide section-py">
    <div class="max-w-[42rem]">
      <span class="label-tag mb-5" data-animate>Ambientes e serviços</span>
      <h2 class="font-serif text-display-lg text-text-main" data-animate>
        Colabore, atenda e trabalhe com a estrutura certa
      </h2>
      <p class="mt-4 max-w-[35rem] text-body-lg text-text-soft" data-animate>
        Sala de reunião climatizada, escritório privativo com acesso 24h, lounge confortável e espaço compartilhado bem equipado. Tudo para sua empresa funcionar com profissionalismo.
      </p>
    </div>

    <div class="mt-8 grid gap-3 md:grid-cols-12" data-animate-group>
      {ambientes.map((item) => (
        <article class:list={["relative", item.className]} data-animate-item>
          <Image
            src={item.image}
            alt={item.label}
            class="h-full w-full object-cover"
            width={1600}
            height={900}
          />

          <div class="media-tab">
            <span class="media-tab__label">{item.label}</span>
            <span class="media-tab__accent"></span>
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="bg-dark text-white">
    <div class="container-wide section-py-sm">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <span class="label-tag mb-5 text-white/70 before:bg-primary" data-animate>Avaliações Google</span>
          <h3 class="font-serif text-display-md text-white" data-animate>Quem já usou, aprovou</h3>
        </div>
        <div class="text-left lg:text-right" data-animate>
          <p class="font-serif text-[1.18rem] leading-none text-white">5 estrelas</p>
          <p class="mt-1 text-[0.78rem] font-medium uppercase tracking-[0.14em] text-white/55">Avaliações no Google</p>
        </div>
      </div>

      <div class="mt-8 grid gap-px overflow-hidden border border-white/12 md:grid-cols-3" data-animate-group>
        {depoimentos.map((depoimento) => (
          <figure class="flex min-h-[16rem] flex-col justify-between bg-dark px-6 py-7" data-animate-item>
            <blockquote class="text-body-md text-white/78">{depoimento.texto}</blockquote>
            <figcaption class="mt-7 flex items-center gap-3 border-t border-white/12 pt-4">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-white/12 text-[0.84rem] font-semibold text-white">
                {depoimento.nome.charAt(0)}
              </span>
              <div>
                <p class="font-serif text-[1rem] text-white">{depoimento.nome}</p>
                <p class="mt-1 text-[0.72rem] font-medium uppercase tracking-[0.12em] text-white/45">Avaliação verificada</p>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>
