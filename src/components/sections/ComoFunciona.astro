---
import { Icon } from "astro-icon/components";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";

const passos = [
  {
    numero: "01",
    titulo: "Fale pelo WhatsApp",
    descricao: "Escolha o serviço, tire suas dúvidas e faça a reserva direto pelo WhatsApp.",
  },
  {
    numero: "02",
    titulo: "Confirme o pagamento",
    descricao: "Depois da confirmação, seu cadastro é liberado para uso do espaço ou do endereço contratado.",
  },
  {
    numero: "03",
    titulo: "Acesse quando quiser",
    descricao: "Você recebe um código exclusivo de entrada. O espaço funciona 24 horas por dia, 7 dias por semana.",
  },
];
---

<section id="como-funciona" class="section-py bg-surface">
  <div class="container-wide">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-[40rem]">
        <span class="label-tag mb-5" data-animate>Como funciona</span>
        <h2 class="font-serif text-display-lg text-text-main" data-animate>
          Do primeiro contato ao acesso, tudo pelo seu celular
        </h2>
      </div>
      <p class="max-w-xl text-body-md text-text-soft" data-animate>
        Sem filas, sem burocracia e sem depender de horário comercial. Reserve, pague e use quando quiser.
      </p>
    </div>

    <div class="mt-8 grid gap-px overflow-hidden border border-border md:grid-cols-3" data-animate-group>
      {passos.map((passo) => (
        <article class="bg-surface px-6 py-7" data-animate-item>
          <div class="flex items-center gap-3">
            <span class="font-serif text-[1.15rem] leading-none text-primary">{passo.numero}</span>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <h3 class="mt-4 font-serif text-[1.02rem] leading-6 text-text-main">{passo.titulo}</h3>
          <p class="mt-3 text-body-md text-text-soft">{passo.descricao}</p>
        </article>
      ))}
    </div>

    <div class="mt-7 flex justify-center" data-animate>
      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-tracking="click-whatsapp-como-funciona"
        data-section="como-funciona"
        class="btn-primary"
      >
        <Icon name="lucide:message-circle" class="h-4 w-4" />
        Falar agora e reservar meu espaço
      </a>
    </div>
  </div>
</section>
