---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import ctaFinalFundo from "../../assets/images/cta_final_fundo_webp.webp";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";
---

<section class="bg-surface">
  <div class="container-wide section-py">
    <div class="relative" data-animate-scale>
      <Image
        src={ctaFinalFundo}
        alt="Fundo CTA final - Endereco de prestigio"
        class="aspect-[1920/760] w-full object-cover rounded-lg"
        width={1920}
        height={760}
      />

      <div class="cta-panel surface-card w-full bg-primary p-6 text-white md:absolute md:left-[5%] md:top-[13%] md:w-[23rem] md:border-primary">
        <span class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-white/75">Fale com a WeShare</span>
        <h2 class="mt-4 font-serif text-display-md text-white">
          Sua empresa com endereco de prestigio a partir de hoje
        </h2>
        <p class="mt-3 text-body-md text-white/82">
          Sem burocracia, sem prazo de fidelidade e sem complicacao. Fale agora pelo WhatsApp e receba a documentacao no mesmo dia da assinatura.
        </p>
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-tracking="click-whatsapp-cta-final"
          data-section="cta-final"
          class="mt-5 inline-flex btn-dark border-white bg-dark px-4.5 py-2.5"
        >
          <Icon name="lucide:message-circle" class="h-4 w-4" />
          Falar com a WeShare agora
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-panel {
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.14);
  }

  @media (max-width: 767px) {
    .cta-panel {
      margin-top: 1rem;
    }
  }
</style>
