---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import logoBranca from "../../assets/images/logo-weshare-branca.webp";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";
const EMAIL = "contato@wesharescritorios.com.br";
const INSTAGRAM = "https://www.instagram.com/wesharescritorios";
const MAPS_URL =
  "https://www.google.com/maps/search/?api=1&query=Ed.+Medison+Tower+Jardim+Aqu%C3%A1rius+S%C3%A3o+Jos%C3%A9+dos+Campos";

const navItems = [
  { label: "Serviços", href: "#servicos" },
  { label: "Como funciona", href: "#como-funciona" },
  { label: "Preços", href: "#precos" },
];
---

<footer id="footer" class="bg-dark text-white">
  <div id="localizacao" aria-hidden="true" style="height:0;visibility:hidden;overflow:hidden;"></div>
  <div class="container-wide py-14">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-[1.1fr_1fr_0.78fr_0.82fr]">
      <div>
        <Image src={logoBranca} alt="WeShare Escritorios Compartilhados" class="mb-6 h-9 w-auto" width={160} height={36} />
        <p class="mt-5 max-w-md text-body-md text-white/65">
          Endereco fiscal, escritorios privativos, sala de reuniao e uso compartilhado no Jardim Aquarius, Sao Jose dos Campos.
        </p>
        <div class="mt-6 flex flex-col gap-2.5 text-body-sm text-white/72">
          <p>Av. Alfredo Ignacio Nogueira Penido, 335, Ed. Medison Tower, Sala 706, Jardim Aquarius, Sao Jose dos Campos, SP, CEP 12246-000</p>
          <a href="tel:+5512982710971" class="inline-flex w-fit items-center gap-2 hover:text-white">
            <Icon name="lucide:phone" class="h-4 w-4 text-primary" />
            (12) 98271-0971
          </a>
          <a href={INSTAGRAM} target="_blank" rel="noopener noreferrer" class="inline-flex w-fit items-center gap-2 hover:text-white">
            <Icon name="lucide:instagram" class="h-4 w-4 text-primary" />
            @wesharescritorios
          </a>
        </div>
      </div>

      <div class="border border-white/12 p-5">
        <span class="label-tag text-white/70 before:bg-primary">Contato rapido</span>
        <h3 class="mt-4 font-serif text-[1.08rem] leading-6 text-white">Receba atendimento e orientacao pelo WhatsApp</h3>
        <p class="mt-3 text-body-md text-white/65">
          Fale agora para consultar disponibilidade, valores das salas fisicas e documentacao para o endereco fiscal.
        </p>
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-tracking="click-whatsapp-footer"
          data-section="footer"
          class="mt-5 inline-flex btn-primary border-primary bg-primary px-4.5 py-2.5"
        >
          Fale pelo WhatsApp
        </a>
      </div>

      <nav aria-label="Links do rodape">
        <h3 class="text-[0.78rem] font-semibold uppercase tracking-[0.16em] text-white/55">Navegação</h3>
        <ul class="mt-4 flex flex-col gap-2.5 text-body-sm text-white/74">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="hover:text-white">{item.label}</a>
            </li>
          ))}
          <li>
            <a href={MAPS_URL} target="_blank" rel="noopener noreferrer" class="hover:text-white">Localização</a>
          </li>
        </ul>
      </nav>

      <div>
        <h3 class="text-[0.78rem] font-semibold uppercase tracking-[0.16em] text-white/55">Atendimento</h3>
        <p class="mt-4 text-body-sm text-white/74">
          Reservas pelo WhatsApp, todos os dias. Acesso ao espaco 24h por dia, 7 dias por semana.
        </p>
        <div class="mt-5">
          <button
            id="theme-toggle"
            type="button"
            aria-label="Alternar tema claro e escuro"
            class="inline-flex items-center gap-2 border border-white/20 px-3 py-2 text-[0.78rem] font-medium uppercase tracking-[0.12em] text-white/75"
          >
            <Icon id="theme-icon-sun" name="lucide:sun" class="hidden h-4 w-4" aria-hidden="true" />
            <Icon id="theme-icon-moon" name="lucide:moon" class="h-4 w-4" aria-hidden="true" />
            <span id="theme-label">Tema escuro</span>
          </button>
        </div>
        <div class="mt-5 flex flex-col gap-2 text-body-sm text-white/74">
          <a href={`mailto:${EMAIL}`} class="hover:text-white">{EMAIL}</a>
          <a href="/politica-de-privacidade" class="hover:text-white">Politica de Privacidade</a>
          <a href="/termos-de-uso" class="hover:text-white">Termos de Uso</a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-white/12 pt-5">
      <span class="text-[0.72rem] uppercase tracking-[0.14em] text-white/38">
        © 2026 WeShare Escritórios Compartilhados. Todos os direitos reservados.
      </span>
      <a href="https://adsgator.com.br" target="_blank" rel="noopener noreferrer" aria-label="Site desenvolvido pela Adsgator" class="opacity-40 transition-opacity hover:opacity-70">
