---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import heroPrincipal from "../../assets/images/hero_principal_webp.webp";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";
---

<section id="hero-section" class="section-py relative overflow-hidden bg-primary">
  <div class="hero-grid absolute inset-0"></div>
  <div class="container-wide relative z-10">
    <div class="grid gap-7 lg:grid-cols-[minmax(0,1fr)_9.5rem] lg:items-start">
      <div class="max-w-[44rem]">
        <span class="label-tag mb-5 text-white" data-animate>Endereco fiscal e escritorios no Jardim Aquarius</span>
        <h1 class="font-serif text-display-xl text-white" data-animate>
          Seu CNPJ com endereco de prestigio no Jardim Aquarius
        </h1>
        <p class="mt-5 max-w-[36rem] text-body-lg text-white/85" data-animate>
          Registre ou transfira sua empresa por <strong class="font-semibold text-text-main">R$ 119,90 por mes</strong>.
          Documentacao liberada no mesmo dia da assinatura, sem prazo de fidelidade e com gestao de correspondencia inclusa.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row" data-animate>
          <a
            href={WA_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-tracking="click-whatsapp-hero"
            data-section="hero"
            class="btn-primary bg-white text-primary hover:bg-white/90"
          >
            <Icon name="lucide:message-circle" class="h-4 w-4" />
            Quero meu endereco fiscal agora
          </a>
          <a href="tel:+5512982710971" class="btn-ghost border-white text-white hover:bg-white/10">
            <Icon name="lucide:phone" class="h-4 w-4" />
            (12) 98271-0971
          </a>
        </div>
      </div>

      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-tracking="click-whatsapp-hero-card"
        data-section="hero"
        class="hero-square-card flex min-h-[8.75rem] flex-col justify-between border border-primary bg-primary p-4 text-white"
        data-animate-right
      >
        <span class="text-[0.66rem] font-semibold uppercase tracking-[0.16em]">Fale agora</span>
        <div class="flex items-end justify-between gap-3">
          <span class="font-serif text-[0.96rem] leading-5">Receba a documentacao no mesmo dia</span>
          <Icon name="lucide:arrow-up-right" class="h-4.5 w-4.5 flex-shrink-0" />
        </div>
      </a>
    </div>

    <div class="relative mt-9 lg:mt-10" data-animate-scale>
      <Image
        src={heroPrincipal}
        alt="Fachada principal do WeShare - Escritórios Compartilhados"
        class="rounded-lg"
        width={1600}
        height={900}
      />

      <div class="hero-overlay-card surface-card max-w-[20rem] bg-dark/92 p-5 text-white md:absolute md:left-[5%] md:top-[10%] md:border-dark">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-white/70">WeShare Escritorios Compartilhados</p>
        <p class="mt-3 text-[0.94rem] leading-6 text-white/92">
          Endereco fiscal, sala de reuniao, escritorio privativo e estrutura profissional para voce atender,
          trabalhar e posicionar melhor a sua empresa.
        </p>
        <div class="mt-4 h-2.5 w-2.5 bg-primary"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .hero-square-card {
    box-shadow: var(--shadow-float);
  }

  .hero-overlay-card {
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.18);
  }

  @media (max-width: 767px) {
    .hero-overlay-card {
      margin-top: 1rem;
    }
  }
</style>
