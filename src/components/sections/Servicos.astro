---
import { Icon } from "astro-icon/components";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";

const servicos = [
  {
    nome: "Endereco Fiscal e Comercial",
    descricao:
      "Documentacao liberada no mesmo dia para abertura ou transferencia de CNPJ, gestao de correspondencia inclusa e 20% de desconto nas reservas de sala.",
    destaque: "Mais contratado",
    tone: "dark",
  },
  {
    nome: "Escritorio Privativo",
    descricao:
      "Sala planejada para atender clientes ou trabalhar sozinho com total privacidade, com ambiente climatizado, cafe expresso, agua mineral e impressora colorida inclusos.",
    tone: "light",
  },
  {
    nome: "Sala de Reuniao",
    descricao:
      "Espaco para ate 7 pessoas com smart TV, flip-chart, iluminacao natural e a sobriedade certa para negociacoes importantes.",
    tone: "light-soft",
  },
  {
    nome: "Escritorio Compartilhado",
    descricao:
      "Tres estacoes de trabalho em ambiente climatizado, com cafe expresso, agua mineral, impressora colorida e Wi-Fi de qualidade, tudo incluso na reserva.",
    tone: "light",
  },
];
---

<section id="servicos" class="section-py bg-background">
  <div class="container-wide">
    <div class="max-w-[42rem]">
      <span class="label-tag mb-5" data-animate>Servicos</span>
      <h2 class="font-serif text-display-lg text-text-main" data-animate>
        O espaco certo para cada momento do seu negocio
      </h2>
      <p class="mt-4 max-w-[34rem] text-body-lg text-text-soft" data-animate>
        De um endereco fiscal com prestigio a uma sala para a reuniao mais importante do mes.
        Tudo no mesmo lugar, com atendimento agil e estrutura pronta para uso.
      </p>
    </div>

    <div class="mt-8 grid gap-px overflow-hidden border border-border sm:grid-cols-2 lg:grid-cols-4" data-animate-group>
      {servicos.map((servico) => (
        <article
          class:list={[
            "flex min-h-[18rem] flex-col justify-between p-7",
            servico.tone === "dark" ? "bg-dark text-white" : "text-text-main",
            servico.tone === "light" ? "bg-surface-alt" : "",
          ]}
          style={servico.tone === "light-soft" ? "background: color-mix(in srgb, var(--t-surface-alt) 65%, white 35%);" : undefined}
          data-animate-item
        >
          <div>
            <div class="flex items-start justify-between gap-4">
              <h3 class:list={["font-serif text-display-sm", servico.tone === "dark" ? "text-white" : "text-text-main"]}>
                {servico.nome}
              </h3>
              {servico.destaque && (
                <span class="border border-primary/30 bg-primary/8 px-2.5 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-primary">
                  {servico.destaque}
                </span>
              )}
            </div>

            <p class:list={["mt-4 max-w-[18rem] text-body-md", servico.tone === "dark" ? "text-white/72" : "text-text-soft"]}>
              {servico.descricao}
            </p>
          </div>

          <a
            href={WA_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-tracking="click-whatsapp-servico"
            data-section={servico.nome}
            class:list={["link-arrow mt-7", servico.tone === "dark" ? "text-white" : "text-text-main"]}
          >
            Falar no WhatsApp
            <Icon name="lucide:arrow-up-right" class="h-4 w-4" />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
