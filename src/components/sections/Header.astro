---
import { Image } from "astro:assets";
import logoVerde from "../../assets/images/logo-weshare-verde.webp";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";

const navItems = [
  { label: "Servicos", href: "#servicos" },
  { label: "Como funciona", href: "#como-funciona" },
  { label: "Precos", href: "#precos" },
  { label: "Localizacao", href: "#footer" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-border bg-surface/95 backdrop-blur-sm"
  style="will-change: transform; transition: transform 0.3s var(--ease-smooth), box-shadow 0.3s ease;"
>
  <div class="container-wide">
    <div class="flex h-15 items-center justify-between gap-5">
      <a href="/" aria-label="WeShare Escritorios Compartilhados - ir para o inicio">
        <Image src={logoVerde} alt="WeShare Escritorios Compartilhados" class="h-9 w-auto" width={160} height={36} />
      </a>

      <nav class="hidden items-center gap-6 lg:flex" aria-label="Navegacao principal">
        {navItems.map((item) => (
          <a
            href={item.href}
            data-nav-link
            class="nav-link text-[0.71rem] font-semibold uppercase tracking-[0.13em] text-text-soft"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden lg:inline-flex btn-dark px-4.5 py-2.5 text-[0.68rem]"
          aria-label="Fale pelo WhatsApp"
        >
          Fale pelo WhatsApp
        </a>

        <button
          id="mobile-menu-btn"
          aria-label="Abrir menu"
          aria-expanded="false"
          class="flex h-10 w-10 items-center justify-center border border-border text-text-main lg:hidden"
        >
          <svg id="menu-icon" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
          <svg id="close-icon" class="hidden h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-border bg-surface lg:hidden">
    <nav class="container-wide flex flex-col gap-1 py-4" aria-label="Menu mobile">
      {navItems.map((item) => (
        <a href={item.href} class="mobile-nav-link px-3 py-3 text-[0.82rem] font-semibold uppercase tracking-[0.14em] text-text-main">
          {item.label}
        </a>
      ))}
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-dark mt-2 w-full justify-center">
        Fale pelo WhatsApp
      </a>
    </nav>
  </div>
</header>

<div style="height: 3.75rem;" aria-hidden="true"></div>

<style>
  .h-15 {
    height: 3.75rem;
  }

  .nav-link:hover,
  .nav-link.nav-active {
    color: var(--t-primary);
  }

  .mobile-nav-link:hover {
    background: color-mix(in srgb, var(--t-primary) 7%, var(--t-surface));
    color: var(--t-primary);
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(isOpen));
    menuIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  });

  function closeMenu() {
    menu?.classList.add("hidden");
    btn?.setAttribute("aria-expanded", "false");
    menuIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  }

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("click", (e) => {
    const header = document.getElementById("site-header");
    if (header && !header.contains(e.target as Node)) {
      closeMenu();
    }
  });

  const header = document.getElementById("site-header");
  let lastY = window.scrollY;

  window.addEventListener(
    "scroll",
    () => {
      const y = window.scrollY;
      const goingDown = y > lastY;
      const menuOpen = menu && !menu.classList.contains("hidden");

      if (header) {
        if (goingDown && y > 120 && !menuOpen) {
          header.style.transform = "translateY(-100%)";
        } else {
          header.style.transform = "translateY(0)";
        }

        header.style.boxShadow = y > 8 ? "0 1px 0 var(--t-border)" : "none";
      }

      lastY = y;
    },
    { passive: true },
  );

  const navLinks = Array.from(document.querySelectorAll("[data-nav-link]")) as HTMLAnchorElement[];
  const sections = navLinks
    .map((link) => document.querySelector(link.getAttribute("href") || ""))
    .filter((element): element is Element => element !== null);

  if (sections.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }

          const id = entry.target.id;
          navLinks.forEach((link) => {
            link.classList.toggle("nav-active", link.getAttribute("href") === `#${id}`);
          });
        });
      },
      { rootMargin: "-42% 0px -48% 0px" },
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>
