---
import { Icon } from "astro-icon/components";

// Perguntas baseadas apenas em fatos do briefing — nada inventado.
const faqs = [
  {
    q: "Quanto custa o endereço fiscal e comercial?",
    a: "O plano de Endereço Fiscal e Comercial custa R$ 119,90 por mês, com gestão de correspondência inclusa e 20% de desconto em qualquer reserva de sala física.",
  },
  {
    q: "Tem prazo de fidelidade?",
    a: "Não. Você pode cancelar quando quiser, com 30 dias de aviso e sem multa.",
  },
  {
    q: "Em quanto tempo recebo a documentação para abrir ou transferir meu CNPJ?",
    a: "A documentação é liberada no mesmo dia da assinatura, pronta para a abertura ou transferência do seu CNPJ.",
  },
  {
    q: "Em que horário posso usar o espaço?",
    a: "O espaço funciona 24 horas por dia, 7 dias por semana. Após a confirmação do pagamento você recebe um código exclusivo de acesso. As reservas são feitas pelo WhatsApp.",
  },
  {
    q: "Onde fica o escritório?",
    a: "No Ed. Medison Tower, sala 706, no Jardim Aquárius — a região mais valorizada de São José dos Campos / SP.",
  },
  {
    q: "O que está incluso nas reservas de sala?",
    a: "Café expresso, água mineral, impressora colorida, Wi-Fi de qualidade e ambiente climatizado, sem cobranças à parte.",
  },
];
---

<section class="section-py bg-surface">
  <div class="container-content">
    <div class="text-center mb-14">
      <span class="label-tag block mb-3" data-animate>Dúvidas frequentes</span>
      <h2 class="font-serif text-display-lg text-text-main" data-animate>
        Perguntas que recebemos com frequência
      </h2>
    </div>

    <div class="flex flex-col gap-3" data-animate-group>
      {
        faqs.map((f) => (
          <details class="faq-item group bg-background rounded-xl border border-border overflow-hidden" data-animate-item>
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none px-7 py-5 font-sans font-600 text-text-main hover:text-primary transition-colors duration-200">
              {f.q}
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary/8 text-primary flex items-center justify-center transition-transform duration-300 group-open:rotate-45">
                <Icon name="lucide:plus" class="w-4 h-4" aria-hidden="true" />
              </span>
            </summary>
            <div class="faq-body px-7 pb-6 border-t border-border">
              <p class="text-body-sm text-text-soft pt-4 leading-relaxed">{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] {
    border-color: var(--t-primary);
    border-left-width: 3px;
  }

  .faq-item[open] summary {
    color: var(--t-primary);
  }
</style>
