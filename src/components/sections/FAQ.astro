---
const faqs = [
  {
    q: "Quanto custa o endereco fiscal e comercial?",
    a: "O plano de Endereco Fiscal e Comercial custa R$ 119,90 por mes, com gestao de correspondencia inclusa e 20% de desconto em qualquer reserva de sala fisica.",
  },
  {
    q: "Tem prazo de fidelidade?",
    a: "Nao. Voce pode cancelar quando quiser, com 30 dias de aviso e sem multa.",
  },
  {
    q: "Em quanto tempo recebo a documentacao para abrir ou transferir meu CNPJ?",
    a: "A documentacao e liberada no mesmo dia da assinatura, pronta para a abertura ou transferencia do seu CNPJ.",
  },
  {
    q: "Em que horario posso usar o espaco?",
    a: "O espaco funciona 24 horas por dia, 7 dias por semana. Apos a confirmacao do pagamento voce recebe um codigo exclusivo de acesso.",
  },
  {
    q: "Onde fica o escritorio?",
    a: "No Ed. Medison Tower, sala 706, no Jardim Aquarius, em Sao Jose dos Campos / SP.",
  },
  {
    q: "O que esta incluso nas reservas de sala?",
    a: "Cafe expresso, agua mineral, impressora colorida, Wi-Fi de qualidade e ambiente climatizado, sem cobrancas a parte.",
  },
];
---

<section class="section-py bg-background">
  <div class="container-content">
    <div class="max-w-[36rem]">
      <span class="label-tag mb-5" data-animate>Duvidas frequentes</span>
      <h2 class="font-serif text-display-lg text-text-main" data-animate>
        Perguntas que recebemos com frequencia
      </h2>
    </div>

    <div class="mt-8 flex flex-col gap-2.5" data-animate-group>
      {faqs.map((faq) => (
        <details class="border border-border bg-surface px-5 py-4.5" data-animate-item>
          <summary class="cursor-pointer list-none pr-8 text-[0.93rem] leading-6 font-semibold text-text-main">
            {faq.q}
          </summary>
          <p class="mt-3 border-t border-border pt-3 text-body-md text-text-soft">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  summary::-webkit-details-marker {
    display: none;
  }

  details[open] {
    border-color: var(--t-primary);
  }
</style>
