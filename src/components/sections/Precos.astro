---
import { Icon } from "astro-icon/components";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";

const planos = [
  {
    nome: "Endereço Fiscal e Comercial",
    preco: "R$ 119,90",
    periodo: "por mês",
    descricao:
      "Documentação imediata para abertura ou transferência de CNPJ, gestão de correspondência inclusa e 20% de desconto em reservas de sala.",
    faixa: "Plano principal",
    tone: "dark",
  },
  {
    nome: "Escritório Privativo",
    preco: "Sob consulta",
    periodo: "por reserva",
    descricao:
      "Sala reservada para atendimento individual, foco e reuniões privadas, com café expresso, água mineral e impressora colorida inclusos.",
    faixa: "Atendimento privativo",
    tone: "light",
  },
  {
    nome: "Sala de Reunião",
    preco: "Sob consulta",
    periodo: "por reserva",
    descricao:
      "Espaço para até 7 pessoas com smart TV, flip-chart, iluminação natural e o acabamento certo para negociações importantes.",
    faixa: "Reuniões e apresentações",
    tone: "light-dark",
  },
  {
    nome: "Escritório Compartilhado",
    preco: "Sob consulta",
    periodo: "por reserva",
    descricao:
      "Três estações de trabalho em ambiente climatizado, com infraestrutura pronta para quem precisa produzir sem custo fixo alto.",
    faixa: "Uso flexível",
    tone: "light-soft",
  },
];
---

<section id="precos" class="section-py bg-background">
  <div class="container-wide">
    <div class="max-w-[42rem]">
      <span class="label-tag mb-5" data-animate>Preços</span>
      <h2 class="font-serif text-display-lg text-text-main" data-animate>
        Um endereço de prestígio por menos do que você imagina
      </h2>
      <p class="mt-4 max-w-[35rem] text-body-lg text-text-soft" data-animate>
        Sem prazo de fidelidade e com toda a estrutura essencial para manter seu CNPJ em ordem e atender bem quando precisar.
      </p>
    </div>

    <div class="mt-8 flex flex-col gap-2.5" data-animate-group>
      {planos.map((plano) => (
        <article
          class:list={[
            "border border-border",
            plano.tone === "light" ? "bg-surface-alt text-text-main" : "",
            plano.tone === "dark" ? "bg-dark text-white" : "",
          ]}
          style={
            plano.tone === "light-soft"
              ? "background: color-mix(in srgb, var(--t-surface-alt) 70%, white 30%);"
              : plano.tone === "light-dark"
                ? "background: color-mix(in srgb, var(--t-dark) 14%, white 86%);"
                : undefined
          }
          data-animate-item
        >
          <div class="grid gap-4 px-5 py-6 lg:grid-cols-[13.5rem_1px_minmax(0,1fr)_auto] lg:items-center lg:gap-5 lg:px-7">
            <div>
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-primary">
                {plano.nome}
              </p>
              <div class="mt-3">
                <p class:list={["font-serif text-display-md", plano.tone === "dark" ? "text-white" : "text-text-main"]}>
                  {plano.preco}
                </p>
                <p class:list={["mt-1 text-[0.78rem] font-medium uppercase tracking-[0.14em]", plano.tone === "dark" ? "text-white/55" : "text-text-muted"]}>
                  {plano.periodo}
                </p>
              </div>
            </div>

            <div class:list={["hidden h-full lg:block", plano.tone === "dark" ? "bg-white/15" : "bg-border"]}></div>

            <div>
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-primary">
                {plano.faixa}
              </p>
              <p class:list={["mt-2.5 max-w-[31rem] text-body-md", plano.tone === "dark" ? "text-white/74" : "text-text-soft"]}>
                {plano.descricao}
              </p>
            </div>

            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              data-tracking="click-whatsapp-precos"
              data-section={plano.nome}
              class:list={[
                "link-arrow justify-self-start pt-1 lg:justify-self-end lg:pt-0",
                plano.tone === "dark" ? "text-white" : "text-text-main",
              ]}
            >
              Falar agora
              <Icon name="lucide:arrow-up-right" class="h-4 w-4" />
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
