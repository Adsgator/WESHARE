---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import manifestoEquipe from "../../assets/images/manifesto_equipe_webp.webp";

const WA_URL =
  "https://wa.me/5512982710971?text=Ol%C3%A1!%20Vi%20o%20site%20e%20quero%20saber%20mais.";

const microbeneficios = [
  { icon: "lucide:file-check-2", texto: "Documentação imediata" },
  { icon: "lucide:mail", texto: "Gestão de correspondência" },
  { icon: "lucide:clock-3", texto: "Acesso 24h" },
  { icon: "lucide:badge-check", texto: "Sem fidelidade" },
  { icon: "lucide:shield-check", texto: "Ambiente reservado" },
  { icon: "lucide:map-pinned", texto: "Endereço prestigiado" },
  { icon: "lucide:wifi", texto: "Wi-Fi de qualidade" },
  { icon: "lucide:coffee", texto: "Café, água e impressora inclusos" },
];
---

<section class="bg-dark text-white">
  <div class="container-wide section-py">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_13rem] lg:items-start">
      <div class="max-w-[44rem]">
        <span class="label-tag mb-5 text-white/70 before:bg-primary" data-animate>Exclusividade no uso do espaço</span>
        <h2 class="font-serif text-display-lg leading-tight text-white" data-animate>
          Você não aluga uma mesa num coworking.
          <span class="mt-2 inline bg-primary px-2 py-1 text-white">Você usa um escritório completo.</span>
        </h2>
        <p class="mt-5 max-w-[34rem] text-body-md text-white/70" data-animate>
          Nosso diferencial é a exclusividade: nossos clientes utilizam nosso espaço como se fosse dele,
          com sobriedade, praticidade e uma sensação real de pertencimento.
        </p>
      </div>

      <div class="space-y-3 lg:pt-1" data-animate-right>
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-white/60">Contato direto</p>
        <a href="tel:+5512982710971" class="block font-serif text-[1.55rem] leading-none text-white">
          12 98271 0971
        </a>
      </div>
    </div>

    <div class="relative mt-9 lg:mt-10" data-animate-scale>
      <Image
        src={manifestoEquipe}
        alt="Interior do WeShare - Escritório privativo no Jardim Aquárius"
        class="rounded-lg"
        width={1600}
        height={820}
      />

      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-tracking="click-whatsapp-manifesto"
        data-section="manifesto"
        class="manifesto-cta-card absolute bottom-5 right-5 flex w-[10.75rem] flex-col justify-between border border-primary bg-primary p-4 text-white"
      >
        <span class="text-[0.64rem] font-semibold uppercase tracking-[0.16em]">Reservar agora</span>
        <div class="mt-5 flex items-end justify-between gap-3">
          <span class="font-serif text-[1rem] leading-5">Falar com a WeShare</span>
          <Icon name="lucide:arrow-up-right" class="h-4 w-4 flex-shrink-0" />
        </div>
      </a>
    </div>
  </div>

  <div class="text-text-main" style="background: color-mix(in srgb, var(--t-surface-alt) 72%, white 28%);">
    <div class="container-wide section-py-sm">
      <span class="label-tag mb-5" data-animate>Estrutura incluída</span>
      <h3 class="font-serif text-display-md text-text-main" data-animate>
        Uma estrutura completa a serviço do seu negócio
      </h3>

      <div class="mt-7 grid gap-px overflow-hidden border border-border sm:grid-cols-2 lg:grid-cols-4" data-animate-group>
        {microbeneficios.map((item) => (
          <div class="flex items-center gap-3 bg-surface px-4 py-4" data-animate-item>
            <span class="flex h-10 w-10 items-center justify-center border border-border text-primary">
              <Icon name={item.icon} class="h-4.5 w-4.5" />
            </span>
            <span class="text-[0.76rem] font-medium uppercase tracking-[0.07em] text-text-main">{item.texto}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .manifesto-cta-card {
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 767px) {
    .manifesto-cta-card {
      position: static;
      margin-top: 1rem;
      width: 100%;
    }
  }
</style>
