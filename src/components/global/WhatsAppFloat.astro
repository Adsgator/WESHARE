---
// Botão flutuante de WhatsApp.
//
// Visível por padrão. Esconde quando o Hero OU o Footer estão na tela
// (para não competir com os CTAs dessas seções). Se não houver
// #hero-section nem #footer, fica sempre visível.
//
// O número e a mensagem vêm de .env (PUBLIC_WA_NUMBER / PUBLIC_WA_MESSAGE).
// Formato do número: só dígitos com DDI, ex.: 5511999999999.

const waNumber = import.meta.env.PUBLIC_WA_NUMBER || 'SEUNUMERO';
const waMessage =
  import.meta.env.PUBLIC_WA_MESSAGE ||
  'Olá! Vi seu site e gostaria de mais informações.';
const WA_LINK = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;
---

<a
  id="btn-whatsapp-float"
  href={WA_LINK}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar pelo WhatsApp"
  data-tracking="click-whatsapp-flutuante"
  data-section="floating"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-wa rounded-full flex items-center justify-center shadow-float hover:scale-110 transition-all duration-200 opacity-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-wa"
>
  <svg width="26" height="26" viewBox="0 0 24 24" fill="white" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.075.528 4.025 1.456 5.732L0 24l6.458-1.427C8.137 23.497 10.025 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.86 0-3.629-.476-5.182-1.314l-.371-.218-3.831.847.86-3.726-.24-.386A9.927 9.927 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
  </svg>
</a>

<script is:inline>
  (function () {
    var btn = document.getElementById('btn-whatsapp-float');
    if (!btn) return;

    var hero = document.getElementById('hero-section');
    var footer = document.getElementById('footer');

    var heroVisible = false;
    var footerVisible = false;

    function update() {
      var hide = heroVisible || footerVisible;
      btn.classList.toggle('opacity-0', hide);
      btn.classList.toggle('pointer-events-none', hide);
      btn.classList.toggle('opacity-100', !hide);
    }

    if (hero) {
      new IntersectionObserver(function (entries) {
        heroVisible = entries[0].isIntersecting;
        update();
      }, { threshold: 0.1 }).observe(hero);
    }

    if (footer) {
      new IntersectionObserver(function (entries) {
        footerVisible = entries[0].isIntersecting;
        update();
      }, { threshold: 0.1 }).observe(footer);
    }

    update();
  })();
</script>
